# ============================================================
# Digitalarc Prospection - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- Apify (scraping Google Maps) ---
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Actor Google Maps (par defaut : Compass Crawler Google Places)
APIFY_GMAPS_ACTOR=compass/crawler-google-places
# Limite de fiches par requete - cap dur a 50 (plan gratuit)
APIFY_MAX_PLACES_PER_SEARCH=50
# Budget mensuel gratuit a ne pas depasser (arret automatique a 90%)
APIFY_FREE_USD_LIMIT=5

# --- Firecrawl (preuve d'absence ChatGPT par screenshot) ---
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Sheets (CRM) ---
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=

# --- SMTP Hostinger (rotation 4 boites, 400 emails/jour max) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
DAILY_EMAIL_CAP=400

SMTP1_USER=contact1@digitalarc.fr
SMTP1_PASS=
SMTP2_USER=contact2@digitalarc.fr
SMTP2_PASS=
SMTP3_USER=contact3@digitalarc.fr
SMTP3_PASS=
SMTP4_USER=contact4@digitalarc.fr
SMTP4_PASS=

# --- Make (webhooks orchestration) ---
MAKE_WEBHOOK_SCRAPE=
MAKE_WEBHOOK_FOLLOWUP=

# --- Divers ---
# Score minimum pour conserver un prospect (sur 10)
MIN_SCORE=7
