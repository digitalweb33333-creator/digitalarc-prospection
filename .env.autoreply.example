# ============================================================
# Reponse automatique aux prospects - variables additionnelles
# Ajouter ces lignes a votre .env existant (ne remplace rien).
# ============================================================

# --- Resend (envoi des reponses auto depuis contact@digitalarc.fr) ---
# Domaine digitalarc.fr a verifier dans Resend (SPF/DKIM) au prealable.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Joachim - Digitalarc <contact@digitalarc.fr>

# Boite ou doivent revenir les reponses du prospect (doit etre surveillee en IMAP)
SENDER_REPLY_TO=contact@digitalarc.fr

# Logo absolu optionnel dans la signature HTML (sinon: pas d'image)
SENDER_LOGO_URL=https://digitalarc.fr/wp-content/uploads/logo.png

# --- Notification interne ---
NOTIFY_EMAIL=joachim33333@outlook.fr

# --- IMAP (lecture des 4 boites Hostinger) ---
# Les identifiants des boites sont ceux deja definis : SMTP1_USER..SMTP4_USER / SMTP1_PASS..
# Boites reelles : contact@ / pro@ / hello@ / team@digitalarc.fr
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
# Fenetre de scan (jours) des messages entrants
REPLY_SCAN_DAYS=7

# --- Comportement de la reponse auto ---
# Confiance minimale pour repondre automatiquement : low | medium | high
# (en dessous -> escalade : notification a Joachim, pas de reponse auto)
AUTO_REPLY_MIN_CONFIDENCE=medium
# Plafond de reponses auto par execution (securite anti-emballement)
AUTO_REPLY_MAX_PER_RUN=100
